<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#BCBCBC">

        <ImageButton
            android:id="@+id/buttonDrawerToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/drawer_menu"
            android:background="@android:color/transparent"
            android:padding="5dp"/>
    </androidx.appcompat.widget.Toolbar>
    <Button
        android:id="@+id/joguinho"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jogo da memoria!"
        android:backgroundTint="@color/blue">


    </Button>
    <Button

        android:id="@+id/joguinho2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="encontre os animais!"
        android:backgroundTint="@color/blue">


    </Button>

    <Button

        android:id="@+id/joguinho3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Questionario"
        android:backgroundTint="@color/blue">


    </Button>

</LinearLayout>